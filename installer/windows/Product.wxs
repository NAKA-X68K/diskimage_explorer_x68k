<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="diskimage_explorer_x68k"
    Manufacturer="diskimage_explorer_x68k"
    Version="$(var.AppVersion)"
    UpgradeCode="{A4C7F4E3-63E2-4A8D-AC49-3A5078F3B8D1}"
    Language="1041"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of diskimage_explorer_x68k is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="diskimage_explorer_x68k" />
    </StandardDirectory>

    <StandardDirectory Id="CommonProgramsFolder">
      <Directory Id="ProgramMenuDir" Name="diskimage_explorer_x68k" />
    </StandardDirectory>

    <StandardDirectory Id="CommonDesktopFolder" />

    <Feature Id="MainFeature" Title="diskimage_explorer_x68k" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ShortcutComponent" />
    </Feature>

    <Component Id="ShortcutComponent" Directory="INSTALLFOLDER" Guid="*">
      <Shortcut
        Id="ProgramMenuShortcut"
        Directory="ProgramMenuDir"
        Name="diskimage_explorer_x68k"
        Target="[INSTALLFOLDER]diskimage_explorer_x68k.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <Shortcut
        Id="DesktopShortcut"
        Directory="CommonDesktopFolder"
        Name="diskimage_explorer_x68k"
        Target="[INSTALLFOLDER]diskimage_explorer_x68k.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveProgramMenuDir" Directory="ProgramMenuDir" On="uninstall" />
      <RegistryValue Root="HKLM" Key="Software\diskimage_explorer_x68k" Name="ShortcutsInstalled" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Package>
</Wix>
